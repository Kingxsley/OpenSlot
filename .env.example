# --- Core ---
PUBLIC_URL=https://your-app.up.railway.app
JWT_SECRET=please-change-this-to-a-long-random-string

# --- Security ---
# Number of proxy hops in front of the app (Railway = 1). Controls which
# X-Forwarded-For value is trusted for logging/rate limiting. Do NOT set to a
# huge number or 'true' in production — clients could spoof their IP.
TRUST_PROXY=1
# Per-IP rate limits (optional; sensible defaults apply if unset).
RATE_LOGIN_MAX=100
RATE_FORGOT_MAX=5
RATE_SIGNUP_MAX=15

# --- URLs ---
# Set BASE_DOMAIN to enable org subdomains like riverside.openslot.org
# (needs a wildcard DNS record *.openslot.org pointing at this app).
BASE_DOMAIN=

# --- Reviewer login (you verify NGOs at /review) ---
REVIEWER_EMAIL=you@yourdomain.org
REVIEWER_PASSWORD=a-strong-reviewer-password
REVIEW_NOTIFY_EMAIL=you@yourdomain.org

# --- Database ---
# Blank = local JSON file (testing). Set to MongoDB Atlas for production.
MONGODB_URI=
MONGODB_DB=openslot
DATA_DIR=./data

# --- Email (optional, free) ---
# Pick ONE transport. All need SMTP_FROM = a verified sender address.
# Order of preference if several are set: Resend, then Brevo, then SMTP.
#
# 1) Resend (recommended free option: 3,000/mo, 100/day, simple HTTPS API).
#    Sign up at resend.com, verify your domain, create an API key.
RESEND_API_KEY=
EMAIL_FROM_NAME=Enjeeoh
#
# 2) Brevo HTTP API (free tier; works even when SMTP ports are blocked).
BREVO_API_KEY=
#
# 3) Gmail shortcut (FREE, no domain needed). Set just these two and it sends via
#    Gmail, from your Gmail address. Get an "App password" at
#    Google Account -> Security -> 2-Step Verification -> App passwords.
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
#
# 3b) Or full generic SMTP (MailerSend, SMTP2GO, custom mail server...).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
#
# From address. Required for Resend/Brevo/SMTP (must be a domain you control).
# For the Gmail shortcut you can leave this blank; it uses GMAIL_USER.
SMTP_FROM=

# --- SMS reminders (optional, Twilio) ---
# Leave blank to keep SMS off (email reminders still work). When set, bookers who
# provide a phone number get an SMS reminder ~24h before their appointment.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
